{
  "version": 2,
  "builds": [
    {
      "src": "src/api/webhook.ts",
      "use": "@vercel/node"
    },
    {
      "src": "src/api/l.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "src/api/webhook.ts" },
    { "src": "/api/l", "dest": "src/api/l.ts" }
  ]
}
